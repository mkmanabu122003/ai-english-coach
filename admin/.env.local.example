# Firebase Admin SDK (service account JSON, base64 encoded)
FIREBASE_SERVICE_ACCOUNT=

# Firebase Client SDK (for auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Session cookie
SESSION_COOKIE_SECRET=your-session-cookie-secret

# LINE Messaging API (for admin message sending)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN_ES=
