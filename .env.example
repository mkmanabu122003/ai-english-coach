# Google Cloud
GCP_PROJECT_ID=your_gcp_project_id

# LINE Messaging API (English Bot)
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# LINE Messaging API (Spanish Bot)
LINE_CHANNEL_SECRET_ES=your_line_channel_secret_es
LINE_CHANNEL_ACCESS_TOKEN_ES=your_line_channel_access_token_es

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Development only (set NODE_ENV=development to use .env instead of Secret Manager)
NODE_ENV=development
